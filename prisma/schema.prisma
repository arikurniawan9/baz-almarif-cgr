// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  PETUGAS
}

enum ZakatType {
  BERAS
  UANG
}

model User {
  id        String   @id @default(cuid())
  name      String
  username  String?  @unique
  email     String?  @unique
  password  String?
  role      Role     @default(PETUGAS)
  active    Boolean  @default(true)
  muzakki   Muzakki[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Muzakki {
  id           String    @id @default(cuid())
  nama         String
  alamat       String
  jumlahJiwa   Int
  jenisZakat   ZakatType
  jumlahBeras  Float     @default(0)
  jumlahUang   Float     @default(0)
  petugasId    String
  petugas      User      @relation(fields: [petugasId], references: [id])
  tanggal      DateTime  @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Setting {
  id               String @id @default("default")
  hargaBeras       Float
  tahunZakat       String
  identitasPanitia String // JSON stored as string or just a string
  updatedAt        DateTime @updatedAt
}
